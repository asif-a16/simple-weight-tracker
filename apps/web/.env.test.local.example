# Copy to .env.test.local and fill in your test user credentials
# This user must already exist in Supabase (email confirmation not required if you pre-confirm)
E2E_EMAIL=your-test-user@example.com
E2E_PASSWORD=your-test-password

# Optional: override the base URL (defaults to http://localhost:3000)
# E2E_BASE_URL=http://localhost:3000

# Supabase credentials (copy from .env.local — needed for Supabase client in e2e helpers)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
