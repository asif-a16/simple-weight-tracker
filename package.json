{
  "name": "simple-weight-tracker",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "pnpm --filter @simple-wt/shared test",
    "test:e2e": "pnpm --filter web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.5.4",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "react-native": "0.83.4",
      "react-native-worklets": "0.7.x"
    }
  }
}
